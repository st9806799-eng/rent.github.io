DATABASE_URL="file:./dev.db"
AUTH_SECRET="change-me-to-a-long-random-string-in-production"
ADMIN_EMAIL="admin@example.com"

# Telegram (опционально): ОДИН бот на всё приложение — задаёт только админ в .env.
# Владельцы бизнесов в кабинете указывают только свой Chat ID (куда слать алерты).
# Клиенты открывают ссылку на ЭТОГО ЖЕ бота для напоминаний.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="YourBotNameWithoutAt"
# Залиште порожнім, доки не налаштуєте вебхук. Якщо заповните — той самий рядок має передаватись у setWebhook як secret_token (npm run telegram:set-webhook).
TELEGRAM_WEBHOOK_SECRET=""
CRON_SECRET="random-string-for-cron"

# Публічна HTTPS-адреса сайту (обов’язково для LiqPay і Telegram server_url)
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Публічна банка Monobank (1 ₴) — показується перед переходом «Підтвердити бронювання» → Telegram.
NEXT_PUBLIC_MONOBANK_JAR_URL="https://send.monobank.ua/jar/9aR5cytJDb/"

# Monobank (еквайринг): токен API з https://web.monobank.ua/ — якщо задано, має пріоритет над LiqPay.
# Після броні користувача перекидає на сторінку оплати Monobank (сума з BOOKING_HOLD_UAH, мін. 1 ₴).
# Webhook не використовується — бронь одразу підтверджена в системі.
MONOBANK_MERCHANT_TOKEN=""

# LiqPay — утримання при броні (1 ₴ за замовчуванням). Увімкнено лише якщо Monobank не налаштовано.
LIQPAY_PUBLIC_KEY=""
LIQPAY_PRIVATE_KEY=""
# LIQPAY_SANDBOX=1
# BOOKING_HOLD_UAH=1
# BOOKING_HOLD_MINUTES=30
