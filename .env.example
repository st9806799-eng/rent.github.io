DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rent?schema=public"
AUTH_SECRET="change-me-to-a-long-random-string-in-production"
ADMIN_EMAIL="admin@example.com"

# Telegram (опционально): ОДИН бот на всё приложение — задаёт только админ в .env.
# Владельцы бизнесов в кабинете указывают только свой Chat ID (куда слать алерты).
# Клиенты открывают ссылку на ЭТОГО ЖЕ бота для напоминаний.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="YourBotNameWithoutAt"
# Залиште порожнім, доки не налаштуєте вебхук. Якщо заповните — той самий рядок має передаватись у setWebhook як secret_token (npm run telegram:set-webhook).
TELEGRAM_WEBHOOK_SECRET=""
CRON_SECRET="random-string-for-cron"

# Публічна HTTPS-адреса сайту (бажано для коректних посилань у сповіщеннях)
NEXT_PUBLIC_APP_URL="https://your-domain.com"
